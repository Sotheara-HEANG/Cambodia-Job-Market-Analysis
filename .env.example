# Copy this file to .env and update the values before loading to PostgreSQL.
DB_HOST=localhost
DB_PORT=5433
DB_NAME=cambodia_job_market_analysis
DB_USER=postgres
DB_PASSWORD=postgres

# Optional scraper settings
SCRAPER_DELAY_SECONDS=2
SCRAPER_MAX_RECORDS_PER_SOURCE=50
SCRAPER_TARGET_TOTAL_RECORDS=12000

# Optional override. Leave blank/commented to spread SCRAPER_TARGET_TOTAL_RECORDS
# across all configured sources.
# SCRAPER_TARGET_RECORDS_PER_SOURCE=1000

# Options: live_with_fallback, sample
SCRAPER_MODE=live_with_fallback
